{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "mqtt-route": {
        "ClusterId": "mqtt-cluster",
        "Match": { "Path": "/mqtt" }
      }
    },
    "Clusters": {
      "mqtt-cluster": {
        "Destinations": {}
      }
    }
  }
}
